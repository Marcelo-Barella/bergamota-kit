{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "meta": {
    "grid": {
      "unitPx": 8,
      "convention": "Spacing values are multiples of 8px (0 allowed). Half-step (4px) is reserved for internal hairline/divider rhythm only—not for layout grids."
    },
    "palette": {
      "base": "Restrained neutrals on a warm cream canvas; chroma concentrated in semantic terracotta accent tokens only—no alternate accent hues.",
      "accent": "terracotta"
    }
  },
  "spacing": {
    "0": { "value": "0px", "gridSteps": 0 },
    "1": { "value": "8px", "gridSteps": 1 },
    "2": { "value": "16px", "gridSteps": 2 },
    "3": { "value": "24px", "gridSteps": 3 },
    "4": { "value": "32px", "gridSteps": 4 },
    "5": { "value": "40px", "gridSteps": 5 },
    "6": { "value": "48px", "gridSteps": 6 },
    "7": { "value": "56px", "gridSteps": 7 },
    "8": { "value": "64px", "gridSteps": 8 },
    "9": { "value": "72px", "gridSteps": 9 },
    "10": { "value": "80px", "gridSteps": 10 },
    "11": { "value": "88px", "gridSteps": 11 },
    "12": { "value": "96px", "gridSteps": 12 },
    "hairline": { "value": "4px", "gridSteps": null, "note": "Hairline only; prefer grid multiples for layout." }
  },
  "color": {
    "cream": {
      "50": { "hex": "#FEFDFB" },
      "100": { "hex": "#FAF7F2" },
      "150": { "hex": "#F5EFE6" },
      "200": { "hex": "#EDE6D9" },
      "300": { "hex": "#D9D0C2" },
      "400": { "hex": "#B8AEA0" }
    },
    "ink": {
      "950": { "hex": "#1C1814" },
      "800": { "hex": "#3D3834" },
      "600": { "hex": "#5C564F" },
      "500": { "hex": "#6F6860" },
      "400": { "hex": "#9A9288" },
      "200": { "hex": "#C9C4BC" },
      "100": { "hex": "#E8E6E2" }
    },
    "terracotta": {
      "50": { "hex": "#FDF6F4" },
      "100": { "hex": "#F9EAE5" },
      "300": { "hex": "#E8A892" },
      "500": { "hex": "#C86244" },
      "700": { "hex": "#9A4228" },
      "900": { "hex": "#5F2615" },
      "onAccent": { "hex": "#FEFDFB", "usage": "Text and icons placed on filled terracotta surfaces." }
    },
    "semantic": {
      "canvas": "{cream.100}",
      "surface": "{cream.50}",
      "surfaceMuted": "{cream.150}",
      "border": "{ink.100}",
      "borderStrong": "{ink.200}",
      "text": "{ink.950}",
      "textMuted": "{ink.600}",
      "textSubtle": "{ink.500}",
      "accent": "{terracotta.500}",
      "accentHover": "{terracotta.700}",
      "accentSoftBg": "{terracotta.100}",
      "focusRing": "{terracotta.500}"
    },
    "_note_semantic_duplicates": "Semantic keys map visually to ink and terracotta ramps only—no secondary accent hues."
  },
  "typography": {
    "family": {
      "display": {
        "css": "\"Fraunces\", Georgia, \"Times New Roman\", serif",
        "role": "Headings and editorial display moments on landing and marketing surfaces.",
        "weights": ["400", "500", "600", "700"],
        "source": "Open Font License; load via your app or substitute a comparable soft-serif."
      },
      "sans": {
        "css": "Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
        "role": "Body text and UI chrome (dashboard controls, dense tables).",
        "weights": ["400", "500", "600", "700"]
      }
    },
    "scale": {
      "display-xl": {
        "fontSizePx": 40,
        "lineHeightPx": 44,
        "fontSizeRem": "2.5",
        "lineHeight": "1.1",
        "weightRecommended": "600",
        "role": "Primary landing hero headings."
      },
      "display-lg": {
        "fontSizePx": 32,
        "lineHeightPx": 40,
        "fontSizeRem": "2",
        "lineHeight": "1.25",
        "weightRecommended": "600",
        "role": "Landing section titles and KPI module titles on dashboards."
      },
      "display-md": {
        "fontSizePx": 24,
        "lineHeightPx": 32,
        "fontSizeRem": "1.5",
        "lineHeight": "1.33",
        "weightRecommended": "600",
        "role": "Card titles (dashboard)."
      },
      "body-lg": {
        "fontSizePx": 18,
        "lineHeightPx": 28,
        "fontSizeRem": "1.125",
        "lineHeight": "1.56",
        "weightRecommended": "400",
        "role": "Marketing lead paragraphs; optional relaxed lists on landing."
      },
      "body-md": {
        "fontSizePx": 16,
        "lineHeightPx": 24,
        "fontSizeRem": "1",
        "lineHeight": "1.5",
        "weightRecommended": "400",
        "role": "Default UI copy and form labels."
      },
      "body-sm": {
        "fontSizePx": 14,
        "lineHeightPx": 20,
        "fontSizeRem": "0.875",
        "lineHeight": "1.43",
        "weightRecommended": "400",
        "role": "Captions, helper text, table cells where density matters."
      },
      "label": {
        "fontSizePx": 12,
        "lineHeightPx": 16,
        "fontSizeRem": "0.75",
        "lineHeight": "1.33",
        "weightRecommended": "600",
        "letterSpacingEm": "0.04",
        "role": "Uppercase or tabular labels in dashboards (use letter-spacing via utility)."
      }
    }
  }
}
